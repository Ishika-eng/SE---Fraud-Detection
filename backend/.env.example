# Copy this file to .env and fill in real values before running

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace-with-a-strong-random-secret

# LLM support (Optional — for auto-decision)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=fraud_detection_db
MODEL_NAME=all-MiniLM-L6-v2

# Comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=["http://localhost:5173"]
